# Конфигурация для парсера вакансий hh.ru

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/hh_parser

# Настройки парсера
DEFAULT_VACANCIES_COUNT=50
HH_API_BASE_URL=https://api.hh.ru
HH_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36
HH_ACCESS_TOKEN=

# Observability
LOG_LEVEL=INFO
LOG_FORMAT=json
PROMETHEUS_ENABLED=true
